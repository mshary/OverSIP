FROM ruby:2.7

WORKDIR /app

# Install build dependencies including OpenSSL for stud
RUN apt-get update && apt-get install -y \
    build-essential \
    libssl-dev \
    libudns-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy the project including the patch script
COPY . .

# Install gems
RUN bundle install

# Patch Rakefile to remove stud dependency from test task
RUN ruby patch_rakefile.rb

# Run tests
CMD ["rake", "test"]
